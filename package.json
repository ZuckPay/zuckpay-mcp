{
  "name": "zuckpay-mcp",
  "version": "0.3.0",
  "description": "Servidor MCP oficial da ZuckPay — crie cobranças PIX, SPEI e PayPal e consulte transações direto do seu assistente de IA.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZuckPay/zuckpay-mcp.git"
  },
  "homepage": "https://github.com/ZuckPay/zuckpay-mcp#readme",
  "bugs": {
    "url": "https://github.com/ZuckPay/zuckpay-mcp/issues"
  },
  "type": "module",
  "bin": {
    "zuckpay-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.17"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "start:http": "node dist/http.js",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "security:audit": "npm audit --audit-level=high",
    "inspector": "npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.25.30"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/node": "^20.14.0",
    "eslint": "^9.9.0",
    "eslint-plugin-security": "^3.0.1",
    "prettier": "^3.3.0",
    "tsup": "^8.2.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.10"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "zuckpay",
    "pix",
    "spei",
    "paypal",
    "pagamentos",
    "gateway",
    "ai"
  ]
}
