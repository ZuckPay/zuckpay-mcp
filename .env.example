# ============================================================
# zuckpay-mcp — variáveis de ambiente
#
# ATENÇÃO: o servidor MCP NÃO carrega este arquivo automaticamente.
# As variáveis devem ser definidas no bloco "env" da configuração
# do seu cliente MCP (Claude Code, Claude Desktop, Cursor...).
# Este arquivo existe apenas como referência dos nomes esperados.
# NUNCA commite credenciais reais.
# ============================================================

# Credenciais de integração (painel ZuckPay > Desenvolvedores > Credenciais API)
ZUCKPAY_CLIENT_ID=
ZUCKPAY_CLIENT_SECRET=

# Opcional: habilita a tool de saque PIX (padrão: desabilitada por segurança)
# ZUCKPAY_ENABLE_WITHDRAW=true

# Opcional: sobrescreve a base da API (apenas https://).
# Padrão: https://www.zuckpay.com.br/conta
# ZUCKPAY_BASE_URL=

# ── Somente para o modo HTTP hospedado (dist/http.js) ──
# Porta do serviço (Railway injeta automaticamente)
# PORT=8080
# Atrás de proxy (Railway/Cloudflare): habilita leitura do X-Forwarded-For
# MCP_TRUST_PROXY=true
# Rate limit por IP por minuto (padrão 60)
# MCP_RATE_LIMIT_PER_MINUTE=60
